  "timelineEvents": [
    {
      "id": "tle_01",
      "memorialId": "default",
      "year": "1948",
      "title": "O Começo de Uma Grande História",
      "description": "Seu nascimento em Minas Gerais, enchendo o lar de risos e uma esperança luminosa.",
      "longStory": "Em 1948, em uma modesta casa no interior de Minas Gerais, nascia João Henrique. Desde pequeno, sua curiosidade pelo funcionamento do mundo e sua determinação silenciosa chamavam a atenção de todos. Sua infância foi repleta de brincadeiras simples e um respeito imenso pela família, valores que pavimentaram cada passo de sua honrosa jornada.",
      "imageUrl": "https://images.unsplash.com/photo-1543269865-cbf427effbad?q=80&w=600"
    },
    {
      "id": "tle_02",
      "memorialId": "default",
      "year": "1972",
      "title": "A Conquista da Engenharia",
      "description": "Sua sonhada formatura acadêmica, abrindo caminhos para uma vida profissional de integridade.",
      "longStory": "Com muito esforço e noites em claro, João Henrique conquistou o sonhado diploma de Engenharia. Ele não via a profissão apenas como técnica, mas como uma forma de construir pontes reais entre as pessoas e melhorar vidas. Sua liderança sempre foi admirada pela gentileza e pelo respeito dado a todos os colegas de trabalho.",
      "imageUrl": "https://images.unsplash.com/photo-1523050854058-8df90110c9f1?q=80&w=600"
    },
    {
      "id": "tle_03",
      "memorialId": "default",
      "year": "1978",
      "title": "A Promessa de Uma Vida a Dois",
      "description": "Seu casamento com Maria de Lourdes, selando uma cumplicidade inabalável.",
      "longStory": "Sob o olhar emocionado de amigos e familiares, João casou-se com Maria de Lourdes, o amor de sua vida. Juntos, eles compartilharam sonhos, superaram tempestades e celebraram conquistas, construindo um lar feliz onde a paciência, o amor genuíno e a união eram a base inabalável de tudo.",
      "imageUrl": "https://images.unsplash.com/photo-1519741497674-611481863552?q=80&w=600"
    },
    {
      "id": "tle_04",
      "memorialId": "default",
      "year": "1985",
      "title": "O Maior Orgulho de Sua Vida",
      "description": "O nascimento de sua filha Ana, trazendo um novo significado e uma doçura sem igual aos seus dias.",
      "longStory": "O nascimento de sua única filha, Ana, foi o momento mais transformador da vida de João. Ele costumava dizer que segurar Ana no colo pela primeira vez o ensinou a real dimensão do amor incondicional. Ele foi um pai herói, conselheiro presente e o maior incentivador de cada vitória dela.",
      "imageUrl": "https://images.unsplash.com/photo-1502086223501-7ea6ecd79368?q=80&w=600"
    },
    {
      "id": "tle_05",
      "memorialId": "default",
      "year": "2012",
      "title": "Os Anos Dourados e o Sorriso de Vovô",
      "description": "A chegada de seu primeiro neto, coroando sua maturidade com muitas brincadeiras e afeto puro.",
      "longStory": "Ser avô trouxe de volta a leveza e a alegria da infância para João Henrique. Ele passava horas inventando brincadeiras, contando histórias do passado e mimando seu neto com doces escondidos. Esses anos dourados foram coroados por risos intermináveis, deixando lições eternas de amor.",
      "imageUrl": "https://images.unsplash.com/photo-1507245921392-e90fa558a43b?q=80&w=600"
    }
  ]
